# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name to use for extraction/summarization (fallback if not using Gemini)
OLLAMA_MODEL=llama3.2:3b

# Gemini API key (used if set - takes priority over local Ollama). Get one at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Gemini model name (optional override)
GEMINI_MODEL=gemini-flash-lite-latest

# Directory paths (override defaults if needed)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
OUTPUTS_DIR=outputs
